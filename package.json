{
  "name": "rothunter",
  "version": "0.4.0",
  "description": "Self-hosted code-hygiene engine for TypeScript / JavaScript codebases. Deterministic detectors + local Tier-3 LLM verdicts + dashboard.",
  "license": "MIT",
  "type": "module",
  "main": "dist/rothunter.js",
  "exports": {
    ".": "./dist/rothunter.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "server": "tsx watch src/server/index.ts",
    "ui": "cd src/ui && npm run dev",
    "dev": "concurrently -k -n SERVER,UI -c blue,magenta \"npm:server\" \"npm:ui\"",
    "docker": "docker compose -f src/docker/docker-compose.yml up --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "depcheck": "depcheck",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "concurrently": "^9.2.1",
    "depcheck": "^1.4.7",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
