{
  "name": "rothunter",
  "version": "0.4.0",
  "description": "Self-hosted code-hygiene engine for TypeScript / JavaScript codebases. Deterministic detectors + local Tier-3 LLM verdicts + dashboard.",
  "license": "MIT",
  "type": "module",
  "main": "dist/rothunter.js",
  "exports": {
    ".": "./dist/rothunter.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "server": "tsx watch src/server/index.ts",
    "ui": "cd src/ui && npm run dev",
    "dev": "concurrently -k -n SERVER,UI -c blue,magenta \"npm:server\" \"npm:ui\"",
    "docker": "docker compose -f src/docker/docker-compose.yml up --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "ts-morph": "^24.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
