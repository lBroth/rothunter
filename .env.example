# rothunter — environment configuration
#
# Copy to `.env` and adjust. Every value has a sane default; set only
# what you need to override. The server reads these at startup.

# ---------- HTTP server ----------------------------------------------------

# Port for the Fastify API + dashboard. Defaults to 3000.
ROTHUNTER_PORT=3000

# Bind address. Defaults to `127.0.0.1` (loopback only). Set to
# `0.0.0.0` ONLY if you understand the API has no authentication —
# every reachable client can read source code under ROTHUNTER_FS_ROOTS.
ROTHUNTER_HOST=127.0.0.1

# ---------- Filesystem access -------------------------------------------------

# Default workspace the server boots into. Falls back to the current
# directory.
# ROTHUNTER_WORKSPACE=/Users/me/code/my-project

# Colon-separated allow-list of directory roots the server is permitted
# to scan. Defaults to the user's home directory (plus `/workspace`
# when present, used by the docker image). Any workspace switch is
# rejected unless the target path resolves inside one of these roots.
# Security-critical — set this to the narrowest possible set in shared
# environments.
# ROTHUNTER_FS_ROOTS=/home/me/code:/var/projects

# ---------- LLM backend ----------------------------------------------------

# Which LLM launcher `scripts/start-llm.mjs` should prefer. Auto-detects
# when unset — picks the first available of `llamacpp`, `docker`.
# ROTHUNTER_LLM_BACKEND=llamacpp

# OpenAI-compatible base URL the server posts to. Defaults to the local
# llama.cpp default `http://127.0.0.1:8080/v1`. Set this to point at a
# remote vLLM / OpenRouter / Together / OpenAI endpoint.
# ROTHUNTER_LLM_BASE_URL=http://127.0.0.1:8080/v1

# HuggingFace repo id (used by both the launcher and the engine to
# pick a model). Defaults to `bartowski/Qwen2.5-Coder-14B-Instruct-GGUF`.
# ROTHUNTER_LLM_MODEL=bartowski/Qwen2.5-Coder-14B-Instruct-GGUF

# GGUF file inside the repo. Only used by the llama.cpp launcher.
# ROTHUNTER_LLM_MODEL_FILE=Qwen2.5-Coder-14B-Instruct-Q4_K_M.gguf

# Bearer token for remote OpenAI-compatible endpoints. Unused for
# local llama.cpp.
# ROTHUNTER_LLM_API_KEY=sk-...

# Parallel LLM verdict requests in flight. Auto-tuned at boot to
# `min(8, cpu_cores / 2)`. Match this to the backend's batching
# capacity (`--parallel N -cb` for llama.cpp, dynamic batching for vLLM).
# ROTHUNTER_LLM_CONCURRENCY=4

# Per-request LLM timeout, ms. Defaults to 120000 (2 min). Long
# enough for cold-start verdicts on Q4 13B+ models.
# ROTHUNTER_LLM_TIMEOUT_MS=120000

# Port the llama.cpp launcher binds. Defaults to 8080.
# ROTHUNTER_LLM_PORT=8080

# ---------- Logging --------------------------------------------------------

# Pino log level. Defaults to `info` (`trace|debug|info|warn|error|fatal`).
# ROTHUNTER_LOG_LEVEL=info
